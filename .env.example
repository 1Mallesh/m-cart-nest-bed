# App
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=1
# Comma-separated allowlist for CORS in production (e.g. https://app.M-Cart.com).
# Leave empty in dev to allow all origins.
CORS_ORIGINS=

# MongoDB
MONGO_URI=mongodb://localhost:27017/M-Cart

# JWT — REQUIRED, min 16 chars. The app refuses to boot with these placeholder
# values; generate strong secrets, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET=replace_with_a_strong_random_secret_min_16
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret
JWT_REFRESH_TTL=7d

# Redis — when set, used as the shared cache (required for multi-instance).
# Without it the app falls back to an in-memory cache (single instance only).
REDIS_URL=

# Kafka — comma-separated broker list (host:port). When set, events are
# published; otherwise they are logged only.
KAFKA_BROKERS=
KAFKA_CLIENT_ID=M-Cart

# OTP
# When MSG91_AUTH_KEY + MSG91_TEMPLATE_ID are set, real SMS OTP is sent via
# MSG91's OTP API. Otherwise OTP falls back to the in-memory mock (dev only),
# which returns the code as `devCode` in non-production.
OTP_TTL_SECONDS=300

# MSG91 (SMS OTP). Get these from your MSG91 dashboard.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_TIMEOUT_MS=8000
MSG91_MAX_RETRIES=2

# Google OAuth
GOOGLE_CLIENT_ID=

# Razorpay (use TEST keys in dev; inject LIVE keys only via a secrets manager in prod)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here
